<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="3dp">

    <!-- 时间戳 -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textSize="11sp"
        android:textColor="#999999"
        android:visibility="gone" />

    <!-- 用户消息 -->
    <LinearLayout
        android:id="@+id/layoutUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="end"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvUserMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_message_user"
                android:maxWidth="280dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                android:clickable="true"
                android:focusable="true"
                android:longClickable="true" />
        </LinearLayout>

        <!-- 用户消息操作栏 (id 带 User 后缀避免与 AI 操作栏冲突) -->
        <LinearLayout
            android:id="@+id/layoutUserActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCopyUser"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="复制"
                android:textSize="12sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnPlayVoiceUser"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="🔊"
                android:textSize="14sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnFavoriteUser"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="⭐"
                android:textSize="14sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnShareUser"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="转发"
                android:textSize="12sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnRegenerateUser"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="🔄重新生成"
                android:textSize="12sp"
                android:textColor="#1E88E5"
                android:background="@drawable/bg_action_btn" />
        </LinearLayout>
    </LinearLayout>

    <!-- AI 消息 -->
    <LinearLayout
        android:id="@+id/layoutBot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBotMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_bot"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="#333333"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            android:visibility="visible"
            android:clickable="true"
            android:focusable="true"
            android:longClickable="true" />

        <TextView
            android:id="@+id/tvLoadingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="4dp"
            android:text="正在搜索..."
            android:textColor="#1E88E5"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTypingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="..."
            android:textColor="#1E88E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutStockTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_message_bot"
            android:padding="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvStockTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#333333"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- AI 消息操作栏 -->
        <LinearLayout
            android:id="@+id/layoutBotActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCopyBot"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="复制"
                android:textSize="12sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnPlayVoiceBot"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="🔊"
                android:textSize="14sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnFavoriteBot"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="⭐"
                android:textSize="14sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnShareBot"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="转发"
                android:textSize="12sp"
                android:textColor="#666666"
                android:background="@drawable/bg_action_btn"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/btnRegenerateBot"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:text="🔄重新生成"
                android:textSize="12sp"
                android:textColor="#1E88E5"
                android:background="@drawable/bg_action_btn" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvErrorHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingLeft="4dp"
            android:text="⚠️ 消息发送失败"
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>