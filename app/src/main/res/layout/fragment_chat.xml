<?xml version="1.0" encoding="utf-8"?>
<!-- 豆包风格 聊天窗口 v13.0 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── 顶部标题栏 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="8dp"
        android:paddingStart="4dp">

        <ImageButton
            android:id="@+id/btnDrawer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="历史对话"
            android:padding="10dp"
            android:src="@drawable/ic_menu_lines" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvChatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:maxEms="12"
                    android:text="@string/app_name"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="›"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="内容由AI生成，请仔细甄别"
                android:textColor="#BBBBBB"
                android:textSize="10sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="更多"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_more"
            app:tint="#666666" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <!-- ── 热门板块提示卡片 (顶部左上角) ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone"
        android:id="@+id/frameHotSectors"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/layoutHotSectors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hot_sector_card"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/tvHotSectorsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔥 今日热门"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHotSectors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="15"
                android:minHeight="120dp"
                android:textColor="#666666"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── 消息列表 ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F7F8FA"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="8dp"
        android:paddingEnd="12dp"
        android:paddingStart="12dp"
        android:paddingTop="8dp" />

    <!-- ── "聊聊新话题" 提示 ── -->
    <TextView
        android:id="@+id/tvNewTopicHint"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#F7F8FA"
        android:gravity="center"
        android:text="聊聊新话题"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- ── 底部输入区 v13.0 紧凑设计 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingBottom="8dp"
        android:paddingTop="6dp">

        <!-- 模式选择栏：快速 / 深度 / 专家（紧凑） -->
        <LinearLayout
            android:id="@+id/modeSelectorBar"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnModeQuick"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="⚡ 快速"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_mode_active"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnModeDeep"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="🔍 深度"
                android:textSize="11sp"
                android:textColor="#666666"
                android:background="@drawable/bg_mode_inactive"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnModeExpert"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="🧠 专家"
                android:textSize="11sp"
                android:textColor="#666666"
                android:background="@drawable/bg_mode_inactive" />
        </LinearLayout>

        <!-- 输入行：⚡ | 输入框 | 🎤 | +/↑ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="4dp"
            android:paddingStart="4dp">

            <!-- ⚡ AI增强按钮（左侧） -->
            <ImageButton
                android:id="@+id/btnAiBoost"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_btn_circle"
                android:contentDescription="AI增强"
                android:padding="6dp"
                android:src="@drawable/ic_ai_boost"
                app:tint="#AAAAAA" />

            <!-- 输入框 -->
            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="发消息..."
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingHorizontal="6dp"
                android:paddingVertical="8dp"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB"
                android:textSize="15sp" />

            <!-- 语音按钮（播放喇叭图标） -->
            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_btn_circle"
                android:contentDescription="语音输入"
                android:padding="5dp"
                android:src="@drawable/ic_voice_speaker" />

            <!-- + 按钮（默认）/ 发送↑按钮（有输入时） -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/bg_send"
                android:contentDescription="更多/发送"
                android:padding="6dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
