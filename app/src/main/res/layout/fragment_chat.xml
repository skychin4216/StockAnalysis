<?xml version="1.0" encoding="utf-8"?>
<!--
  豆包风格 聊天窗口（app1）
  顶部白色标题栏：≡ | 标题 | ⋮
  消息列表
  底部输入：📷 | 输入框 | 🎤 / ➕（空状态时） → ↑ 箭头（有输入时）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── 顶部标题栏（白色，类似豆包 app1）── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="8dp"
        android:paddingStart="4dp">

        <!-- ≡ 两横线返回按钮（回到对话列表） -->
        <ImageButton
            android:id="@+id/btnDrawer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="历史对话"
            android:padding="10dp"
            android:src="@drawable/ic_menu_lines" />

        <!-- 标题区（居中，垂直两行） -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvChatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:maxEms="12"
                    android:text="@string/app_name"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="›"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="内容由AI生成，请仔细甄别"
                android:textColor="#BBBBBB"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 更多菜单（⋮） -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="更多"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#666666" />

    </LinearLayout>

    <!-- 细分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <!-- ── 消息列表 ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F7F8FA"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="8dp"
        android:paddingEnd="12dp"
        android:paddingStart="12dp"
        android:paddingTop="8dp" />

    <!-- ── "聊聊新话题" 提示 ── -->
    <TextView
        android:id="@+id/tvNewTopicHint"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#F7F8FA"
        android:gravity="center"
        android:text="聊聊新话题"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- ── 底部输入区（白色圆角卡片风格）── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingBottom="8dp"
        android:paddingTop="6dp">

        <!-- 输入行：📷 | 输入框 | 🎤 | ➕ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="6dp"
            android:paddingStart="6dp">

            <!-- 📷 相机按钮 -->
            <ImageButton
                android:id="@+id/btnImage"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="图片"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#999999" />

            <!-- 输入框 -->
            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="发消息或按住说话..."
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingHorizontal="6dp"
                android:paddingVertical="8dp"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB"
                android:textSize="15sp" />

            <!-- 🎤 语音按钮（空输入时显示） -->
            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="语音输入"
                android:padding="6dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="#999999" />

            <!-- 发送按钮：空状态显示 ➕，有输入时切换为 ↑ 箭头 -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_send"
                android:contentDescription="发送"
                android:padding="8dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
