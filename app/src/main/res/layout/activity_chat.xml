<?xml version="1.0" encoding="utf-8"?>
<!--
  豆包风格聊天布局
  结构：
  ┌────────────────────────────────────┐
  │          DrawerLayout              │
  │  ┌──────────────┐  ┌──────────┐   │
  │  │ 左侧抽屉      │  │ 主内容   │   │
  │  │ (右滑展开)   │  │ Toolbar  │   │
  │  │ - 新建对话   │  │ Messages │   │
  │  │ - 历史列表   │  │ ──────── │   │
  │  │              │  │ Input    │   │
  │  │ - 账号信息   │  │ Actions  │   │
  │  └──────────────┘  └──────────┘   │
  └────────────────────────────────────┘
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ════════════════════════════════════════
         主内容区域
         ════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部标题栏 -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1E88E5"
            android:elevation="0dp"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <!-- 左侧：打开抽屉按钮（≡） -->
                <ImageButton
                    android:id="@+id/btnDrawer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="历史对话"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#FFFFFF" />

                <!-- App 图标 + 名称 -->
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="logo"
                    android:src="@mipmap/ic_launcher_round" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- 新建对话按钮 -->
                <ImageButton
                    android:id="@+id/btnNewChat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="新建对话"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="#FFFFFF" />

                <!-- 更多菜单按钮 (⋮) -->
                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_more"
                    android:contentDescription="更多"
                    app:tint="#FFFFFF" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

        <!-- 消息列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="8dp"
            android:paddingEnd="12dp"
            android:paddingStart="12dp"
            android:paddingTop="8dp" />

        <!-- ────────────────────────────────────
             底部输入区域（豆包风格）
             输入框 + 发送按钮 在上
             快捷操作按钮行 在下
             paddingBottom 适配系统手势导航栏
             ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingBottom="12dp">

            <!-- 输入框行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:layout_marginEnd="12dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="4dp"
                android:paddingStart="16dp"
                android:paddingVertical="4dp">

                <EditText
                    android:id="@+id/etInput"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/chat_input_hint"
                    android:imeOptions="actionSend"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:paddingVertical="10dp"
                    android:textColor="#333333"
                    android:textColorHint="#999999"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_send"
                    android:contentDescription="发送"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#FFFFFF" />

            </LinearLayout>

            <!-- 快捷操作按钮行（输入框下方，参考豆包） -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="2dp"
                android:paddingStart="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="8dp">

                    <!-- ＋ 附件/图片 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="6dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="+"
                        android:textSize="18sp"
                        app:strokeWidth="1dp" />

                    <!-- ⚡ 快速 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuick"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="6dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="⚡ 快速"
                        android:textSize="12sp"
                        app:strokeWidth="1dp" />

                    <!-- 🔍 深入研究 -->

                    <!-- 📈 股票 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResearch"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="6dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="🔍 深入研究"
                        android:textSize="12sp"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStocks"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="6dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="📈 股票"
                        android:textSize="12sp"
                        app:strokeWidth="1dp" />

                    <!-- ⋮ 更多 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMoreActions"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="⋮ 更多"
                        android:textSize="12sp"
                        app:strokeWidth="1dp" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

    </LinearLayout>

    <!-- ════════════════════════════════════════
         左侧历史对话抽屉（右滑展开）
         ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/navDrawer"
        android:layout_width="288dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="vertical">

        <!-- 抽屉顶部：应用标题 + 新建对话 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#1E88E5"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="logo"
                android:src="@mipmap/ic_launcher_round" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 新建对话图标 -->
            <ImageButton
                android:id="@+id/btnNewChatDrawer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="新建对话"
                android:padding="6dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF" />

        </LinearLayout>

        <!-- 历史对话标签 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="历史对话"
            android:textColor="#888888"
            android:textSize="12sp" />

        <!-- 历史对话列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never" />

        <!-- 底部分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E0E0E0" />

        <!-- 账号信息区域 -->
        <LinearLayout
            android:id="@+id/layoutAccount"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <!-- 头像 -->
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar"
                android:contentDescription="头像"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#FFFFFF" />

            <!-- 账号名 -->
            <TextView
                android:id="@+id/tvAccountName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="我的账号"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- 设置图标 -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="设置"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="#AAAAAA" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
