<?xml version="1.0" encoding="utf-8"?>
<!--
  启动图标前景 - K线上涨图
  设计参考：东方财富 App 风格
  Canvas: 108x108  Safe zone: 22~86 (72x72)
  元素：3根K线蜡烛（左小右大，呈上涨趋势）+ 黄色趋势线 + 上涨箭头
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ════ 底部基线 ════ -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.4"
        android:strokeLineCap="round"
        android:pathData="M22,84 L86,84" />

    <!-- ════ 黄色上升趋势线 ════ -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFEB3B"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:pathData="M26,80 L46,68 L66,52 L84,32" />

    <!-- ════ K线1：左 - 阴线(小) ════ -->
    <!-- 上影线 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M32,61 L32,65" />
    <!-- 阴线体：空心描边，上收下开 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:pathData="M27,65 L37,65 L37,76 L27,76 Z" />
    <!-- 下影线 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M32,76 L32,80" />

    <!-- ════ K线2：中 - 阳线(中) ════ -->
    <!-- 上影线 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M54,44 L54,49" />
    <!-- 阳线体：实心白 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M49,49 L59,49 L59,67 L49,67 Z" />
    <!-- 下影线 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M54,67 L54,71" />

    <!-- ════ K线3：右 - 大阳线 ════ -->
    <!-- 上影线 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M76,24 L76,30" />
    <!-- 大阳线体：实心白 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M71,30 L81,30 L81,58 L71,58 Z" />
    <!-- 下影线 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M76,58 L76,63" />

    <!-- ════ 右上角上涨箭头（黄色） ════ -->
    <!-- 箭头线段：↗ 方向 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFEB3B"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M78,38 L86,28" />
    <!-- 箭头头部（右+上两条边） -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFEB3B"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M80,28 L86,28 L86,34" />

</vector>
